# Database
DATABASE_URL=sqlite:///./pricing_engine.db
TIMESCALEDB_URL=postgresql://pricing_user:secure_password@localhost:5433/pricing_engine

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# External APIs
OPENWEATHERMAP_API_KEY=demo_key
GOOGLE_MAPS_API_KEY=demo_key

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO

# Environment
ENV=development
DEBUG=True

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
PORT=8000 